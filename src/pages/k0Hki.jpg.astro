---
import { Image } from "astro:assets"
import Layout from "../layouts/Layout.astro"
import khat from "../assets/khat.jpg"
---

<Layout title="k0Hki.jpg" description="two khats hugging it out">
  <Image
    src={khat}
    alt="two khats hugging it out"
    class="fixed inset-0 h-full w-full object-contain"
  />
  <audio id="knocking" src="/knocking.mp3" autoplay loop></audio>

  <div id="cookie-modal">
    <div
      id="cookie-backdrop"
      class="fixed inset-0 h-screen w-screen bg-black/80"
    >
    </div>
    <div
      class="fixed top-1/2 left-1/2 z-50 flex max-h-screen min-h-[70vh] w-screen max-w-5xl -translate-x-1/2 -translate-y-1/2 flex-col justify-between gap-8 overflow-y-auto bg-white p-6 text-gray-900 shadow-lg sm:rounded-3xl md:w-[70vw] md:p-12"
    >
      <div class="space-y-8 text-center">
        <div class="text-8xl">🍪</div>
        <p class="text-5xl font-semibold md:text-7xl">Cookies</p>
      </div>
      <div class="text-lg text-slate-500 md:text-xl">
        Cookies are used to access and store information on your device, to
        offer personalized content and ads based on your data. By choosing
        "Accept" you consent to this site and its associated partners to use
        cookies. You can refuse or withdraw consent by choosing "Manage
        settings".
      </div>
      <small class="text-slate-500">
        By clicking accept you agree to this site storing cookies on your device
      </small>
      <button
        id="cookie-accept"
        class="rounded-full bg-slate-800 px-8 py-4 text-2xl font-semibold text-white uppercase transition-colors hover:ring-[3px]"
      >
        Accept
      </button>
      <small
        id="cookie-settings"
        class="cursor-pointer text-center text-slate-500 uppercase hover:underline"
      >
        Manage settings
      </small>
    </div>
  </div>
</Layout>

<script>
  const audio = document.getElementById("knocking") as HTMLAudioElement
  const playAttempt = setInterval(() => {
    audio
      .play()
      .then(() => clearInterval(playAttempt))
      .catch(() => {
        // Autoplay blocked; try again shortly
      })
  }, 500)

  const modal = document.getElementById("cookie-modal")!
  for (const id of ["cookie-backdrop", "cookie-accept", "cookie-settings"]) {
    document.getElementById(id)?.addEventListener("click", () => modal.remove())
  }
</script>
