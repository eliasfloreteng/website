---
interface Props {
  id: string
  title: string
  subtitle: string
}

const { id, title, subtitle } = Astro.props
---

<section
  id={id}
  class="flex h-[85vh] scroll-mt-24 flex-col items-center justify-center border-t border-gray-900"
>
  <div class="flex flex-col justify-center text-center">
    <h2 class="text-6xl font-bold uppercase">{title}</h2>
    <p class="font-soft text-lg">{subtitle}</p>
  </div>
  <slot />
</section>
