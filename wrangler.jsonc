{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "website",
  "compatibility_date": "2026-07-18",
  "main": "worker/index.ts",
  "workers_dev": false,
  "preview_urls": true,
  "routes": [
    { "pattern": "www.floreteng.se", "custom_domain": true },
    { "pattern": "floreteng.se", "custom_domain": true }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
